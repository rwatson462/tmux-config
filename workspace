#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Get first project from config
first_project_name=$(yq -r '.projects[0].name' "$SCRIPT_DIR/projects.yml")
first_project_path=$(yq -r '.projects[0].path' "$SCRIPT_DIR/projects.yml")
session_name=$(echo "$first_project_name" | tr '.:' '_')

# Create session if needed
if ! tmux has-session -t "$session_name" 2>/dev/null; then
    tmux new-session -d -s "$session_name" -c "$first_project_path"
fi

# Source config and attach
tmux source-file "$SCRIPT_DIR/tmux.conf"
exec tmux attach-session -t "$session_name"
